# Copy to .env and fill in. These are exposed to the browser (Vite inlines
# VITE_* vars at build time), so only the public Supabase URL + anon key belong
# here. Never put the service-role key or any LLM API key in this file — those
# live only in Supabase secrets.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
