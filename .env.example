# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the
# browser (Next.js inlines them at build time) — only the public Supabase URL +
# anon key belong there. Never put the service-role key or any LLM API key in
# this file.
#
# Neon/Vercel is the live production backend as of the Phase C cutover.
# Supabase is legacy, kept only for the handful of not-yet-migrated call
# sites documented in CLAUDE.md's "Known issues" section (ScholarLockGate.jsx
# fallback gate, HomePage.jsx's public config-copy read) — decommission
# candidate for Phase D once those are gone.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (no NEXT_PUBLIC_ prefix), never sent to the browser. Get the
# real value from the Neon console; set it in Vercel project env vars for
# deployed environments, never commit it here.
DATABASE_URL=postgresql://user:password@ep-your-endpoint.neon.tech/neondb?sslmode=require

# Server-only. Used by app/api/ask*/route.js; those routes gracefully return
# 503 "not configured" until this is set.
GOOGLE_AI_KEY=your-gemini-api-key
