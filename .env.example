# Copy to .env.local and fill in. NEXT_PUBLIC_* vars are exposed to the
# browser (Next.js inlines them at build time) — only the public Supabase URL +
# anon key belong there. Never put the service-role key or any LLM API key in
# this file — those live only in Supabase secrets.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# neon-migration branch only — server-only (no NEXT_PUBLIC_ prefix), never
# sent to the browser. Get the real value from the Neon console; set it in
# Vercel project env vars for deployed environments, never commit it here.
DATABASE_URL=postgresql://user:password@ep-your-endpoint.neon.tech/neondb?sslmode=require
